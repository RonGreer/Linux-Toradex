	gpio-line-names = "SODIMM_42",
			  "SODIMM_46",
			  "SODIMM_187",
			  "SODIMM_20",
			  "SODIMM_22",
			  "SODIMM_15",
			  "SODIMM_196",
			  "SODIMM_200",
			  "SODIMM_198",
			  "SODIMM_202",
			  "SODIMM_164",
			  "SODIMM_152",
			  "SODIMM_116",
			  "SODIMM_128",
			  "",
			  "",
			  "SODIMM_55",
			  "SODIMM_53",
			  "SODIMM_95",
			  "SODIMM_93",
